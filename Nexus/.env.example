AI_PROVIDER_ORDER=gemini,openrouter,groq

# Role-specific defaults. OpenRouter is first for coding because it can route
# to code-strong Claude/OpenAI-family models through your OpenRouter key.
OBSERVER_PROVIDER_ORDER=gemini,openrouter,groq
CODER_PROVIDER_ORDER=openrouter,gemini,groq
AUDITOR_PROVIDER_ORDER=gemini,openrouter,groq
CLASSIFIER_PROVIDER_ORDER=gemini,openrouter,groq
IMPROVEMENT_PROVIDER_ORDER=gemini,openrouter,groq

GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=your-google-ai-studio-key-here
GEMINI_CHAT_MODEL=gemini-3.5-flash
GEMINI_MODEL=gemini-3.5-flash
GEMINI_OBSERVER_MODEL=gemini-3.5-flash
GEMINI_AUDITOR_MODEL=gemini-3.5-flash
GEMINI_CODER_MODEL=gemini-3.5-flash

OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_APP_TITLE=Universal AI Ecosystem
OPENROUTER_HTTP_REFERER=

# Optional legacy providers. Only used if added to AI_PROVIDER_ORDER.
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
